      <h4>Disclaimer</h4>
      <p>This report is for informational purposes only and is not investment advice. Data
         is sourced from public endpoints and may be delayed, incomplete, or inaccurate.
         Consult a SEBI-registered advisor before making decisions.</p>
    </div>
    <div class="legal-block">
      <h4>Terms of Use</h4>
      <p>Provided "as is" without warranty. The authors take no responsibility for any
         financial loss from use of, or reliance on, this report. Redistribution is
         permitted provided this notice is preserved.</p>
    </div>
    <div class="legal-block">
      <h4>Data Sources</h4>
      <p>Yahoo Finance (indices, FX, Nifty constituents); Moneycontrol (FII/DII, news);
         Tickertape (Market Mood Index); BankBazaar (Chennai bullion). Not affiliated
         with or endorsed by any of these providers.</p>
    </div>
  </div>

  <div class="foot">
    <span>Market Digest · Compiled {{ generated_at.strftime('%H:%M IST · %a, %d %b %Y') }}</span>
    <span>Open-source · personal-use only</span>
  </div>
  <div class="print-footer print-only">
    <span>Market Digest Research · Subscription Copy</span>
    <span>Page 11 of 11</span>
  </div>
</section>

</div><!-- /wrap -->

<script>
const isPrint = window.isPrint;
const COMMON_LAYOUT = {
  paper_bgcolor: 'rgba(0,0,0,0)',
  plot_bgcolor:  'rgba(0,0,0,0)',
  margin: {t: 8, l: 56, r: 12, b: 32},
  font: { family: 'inherit', size: 11, color: '#86868B' },
  xaxis: { gridcolor: 'rgba(0,0,0,0.04)', linecolor: 'rgba(0,0,0,0.06)',
           zerolinecolor: 'rgba(0,0,0,0.06)', tickcolor: 'rgba(0,0,0,0)' },
  yaxis: { gridcolor: 'rgba(0,0,0,0.04)', linecolor: 'rgba(0,0,0,0)',
           zerolinecolor: 'rgba(0,0,0,0,0.12)', tickcolor: 'rgba(0,0,0,0)' },
  showlegend: false,
  hoverlabel: { bgcolor:'#FFFFFF', font:{ color:'#1D1D1F', size:11 }, bordercolor:'rgba(0,0,0,0.06)' }
};

// ---- TradingView Lightweight Charts: Nifty candlestick + sparklines ----
const LWC_BASE = {
  layout: { background: { type: 'solid', color: '#FFFFFF' },
            textColor: '#86868B',
            fontFamily: '"Inter", -apple-system, "Segoe UI", sans-serif' },
  grid: { vertLines: { color: 'rgba(0,0,0,0.04)' },
          horzLines: { color: 'rgba(0,0,0,0.04)' } },
  rightPriceScale: { borderColor: 'rgba(0,0,0,0.08)',
                     scaleMargins: { top: 0.08, bottom: 0.08 } },
  timeScale: { borderColor: 'rgba(0,0,0,0.08)', timeVisible: false,
               rightOffset: 2, fixLeftEdge: true, fixRightEdge: true },
  crosshair: { mode: LightweightCharts.CrosshairMode.Normal,
               vertLine: { color: 'rgba(0,0,0,0.18)', width: 1, style: 3 },
               horzLine: { color: 'rgba(0,0,0,0.18)', width: 1, style: 3 } },
  handleScroll: false, handleScale: false,
};
const LWC_LIGHT = {
  layout: { background: { type: 'solid', color: 'transparent' },
            textColor: '#86868B',
            fontFamily: '"Inter", -apple-system, "Segoe UI", sans-serif' },
  grid: { vertLines: { color: 'rgba(0, 0, 0, 0.04)' },
          horzLines: { color: 'rgba(0, 0, 0, 0.04)' } },
  rightPriceScale: { borderColor: 'rgba(0, 0, 0, 0.06)',
                     scaleMargins: { top: 0.1, bottom: 0.15 } },
  timeScale: { borderColor: 'rgba(0, 0, 0, 0.06)', timeVisible: false,
               rightOffset: 2, fixLeftEdge: true, fixRightEdge: true },
  crosshair: { mode: LightweightCharts.CrosshairMode.Normal,
               vertLine: { color: 'rgba(0, 0, 0, 0.12)', width: 1, style: 3 },
               horzLine: { color: 'rgba(0, 0, 0, 0.12)', width: 1, style: 3 } },
  handleScroll: false, handleScale: false,
};
const SPARK_OPTS = {
  layout: { background: { type: 'solid', color: 'transparent' }, textColor: 'transparent' },
  grid: { vertLines: { visible: false }, horzLines: { visible: false } },
  rightPriceScale: { visible: false },
  leftPriceScale: { visible: false },
  timeScale: { visible: false },
  crosshair: { vertLine: { visible: false }, horzLine: { visible: false } },
  handleScroll: false, handleScale: false,
};

{% if nifty.available %}
(function(){
  const c = {{ nifty.chart | tojson }};
  const sr = {{ nifty.support_resistance | tojson }};

  // ---- Main candlestick (TradingView-style) ----
  const mainEl = document.getElementById('nifty-chart');
  const main = LightweightCharts.createChart(mainEl, {
    ...LWC_LIGHT,
    width: mainEl.clientWidth,
    height: isPrint ? 160 : (mainEl.clientHeight || 180),
  });
  window.niftyChart = main;
  const candle = main.addCandlestickSeries({
    upColor: '#089981', downColor: '#f23645',
    borderUpColor: '#089981', borderDownColor: '#f23645',
    wickUpColor: '#089981', wickDownColor: '#f23645',
    priceLineVisible: false, lastValueVisible: false,
  });
  const cData = c.dates.map((d, i) => ({
    time: d, open: c.open[i], high: c.high[i], low: c.low[i], close: c.close[i]
  }));
  candle.setData(cData);
  const ema = main.addLineSeries({
    color: '#f2a515', lineWidth: 1.5, priceLineVisible: false, lastValueVisible: false,
    crosshairMarkerVisible: false,
  });
  ema.setData(c.dates.map((d, i) => ({ time: d, value: c.ema21[i] })));

  // ---- Clean Candlestick + EMA 21 Only ----
  main.timeScale().fitContent();
  new ResizeObserver(() => main.applyOptions({
    width: mainEl.clientWidth, height: mainEl.clientHeight,
  })).observe(mainEl);

  // ---- Hero sparkline (last 30 closes) ----
  const sparkEl = document.getElementById('hero-spark');
  const lastN = Math.min(30, c.close.length);
  const sparkData = c.dates.slice(-lastN).map((d, i) => ({
    time: d, value: c.close.slice(-lastN)[i]
  }));
  const isUp = sparkData[sparkData.length-1].value >= sparkData[0].value;
  const spark = LightweightCharts.createChart(sparkEl, {
    ...SPARK_OPTS,
    width: sparkEl.clientWidth,
    height: isPrint ? 40 : (sparkEl.clientHeight || 50),
  });
  window.heroSpark = spark;
  const sparkSeries = spark.addAreaSeries({
    lineColor: isUp ? '#00875A' : '#D70015',
    topColor: isUp ? 'rgba(0,135,90,0.20)' : 'rgba(215,0,21,0.20)',
    bottomColor: isUp ? 'rgba(0,135,90,0)' : 'rgba(215,0,21,0)',
    lineWidth: 2, priceLineVisible: false, lastValueVisible: false,
    crosshairMarkerVisible: false,
  });
  sparkSeries.setData(sparkData);
  spark.timeScale().fitContent();
  new ResizeObserver(() => spark.applyOptions({
    width: sparkEl.clientWidth, height: sparkEl.clientHeight,
  })).observe(sparkEl);
})();
{% endif %}

{% if mmi.available %}
(function(){
  Plotly.newPlot('mmi-gauge', [{
    type: 'indicator', mode: 'gauge', value: {{ mmi.current }},
    gauge: {
      axis: { range: [0,100], tickmode:'array', tickvals:[0,30,50,70,100],
              tickfont:{ size: 9, color:'#86868B' }, tickcolor:'rgba(0,0,0,0)' },
      bar: { color: '#1D1D1F', thickness: 0.16 },
      borderwidth: 0,
      bgcolor: 'rgba(0,0,0,0)',
      steps: [
        {range:[0,30], color:'#FBE9EA'},
        {range:[30,50], color:'#FCEFCB'},
        {range:[50,70], color:'#EAF2DC'},
        {range:[70,100], color:'#E6F4EE'},
      ],
    },
  }], {
    width: 260,
    height: 130,
    margin: {t: 10, b: 0, l: 20, r: 20},
    paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
  }, { displayModeBar: false, responsive: false });
})();
{% endif %}

{% if fii_dii.available %}
(function(){
  const c = {{ fii_dii.chart | tojson }};
  const fiiDiiEl = document.getElementById('fii-dii-chart');
  Plotly.newPlot('fii-dii-chart', [
    { x: c.labels, y: c.fii, type: 'bar', name: 'FII',
      marker: { color: '#0071E3', line: {width: 0} },
      hovertemplate: '<b>FII</b> %{y:,.0f} Cr<extra></extra>' },
    { x: c.labels, y: c.dii, type: 'bar', name: 'DII',
      marker: { color: '#86868B', line: {width: 0} },
      hovertemplate: '<b>DII</b> %{y:,.0f} Cr<extra></extra>' }
  ], {
    ...COMMON_LAYOUT,
    width: fiiDiiEl.clientWidth,
    height: isPrint ? 120 : undefined,
    barmode: 'group', bargap: 0.25, bargroupgap: 0.08,
    margin: isPrint ? { t: 8, l: 30, r: 8, b: 35 } : { t: 8, l: 56, r: 12, b: 64 },
    xaxis: { ...COMMON_LAYOUT.xaxis, type: 'category',
             tickangle: -45, tickfont: { size: isPrint ? 8 : 10, color: '#86868B' } },
    yaxis: { ...COMMON_LAYOUT.yaxis, zerolinecolor: 'rgba(0,0,0,0.12)',
             zerolinewidth: 1, ticksuffix: ' ', tickfont: { size: isPrint ? 8 : 11, color: '#86868B' } }
  }, { displayModeBar: false, responsive: true });
})();
{% endif %}

{% if vix.available %}
(function(){
  const v = {{ vix.history | tojson }};
  const vEl = document.getElementById('vix-spark');
  const isUp = v.values[v.values.length-1] >= v.values[0];
  const chart = LightweightCharts.createChart(vEl, {
    ...SPARK_OPTS,
    width: vEl.clientWidth,
    height: isPrint ? 80 : (vEl.clientHeight || 70),
  });
  window.vixSpark = chart;
  const series = chart.addAreaSeries({
    lineColor: isUp ? '#D70015' : '#00875A',
    topColor: isUp ? 'rgba(215,0,21,0.18)' : 'rgba(0,135,90,0.18)',
    bottomColor: isUp ? 'rgba(215,0,21,0)' : 'rgba(0,135,90,0)',
    lineWidth: 2, priceLineVisible: false, lastValueVisible: false,
    crosshairMarkerVisible: false,
  });
  series.setData(v.dates.map((d, i) => ({ time: d, value: v.values[i] })));
  chart.timeScale().fitContent();
  new ResizeObserver(() => chart.applyOptions({
    width: vEl.clientWidth, height: vEl.clientHeight,
  })).observe(vEl);
})();
{% endif %}

// Nav scroll-spy
(function(){
  const ids = ['overview','mood','heatmap','bulletin','flows','volatility','global','gold','silver','score'];
  const sections = ids.map(id => document.getElementById(id)).filter(Boolean);
  const navBtns = document.querySelectorAll('#nav-seg button');
  navBtns.forEach(b => b.addEventListener('click', () => {
    const el = document.getElementById(b.dataset.target);
    if (el) window.scrollTo({ top: el.offsetTop - 70, behavior: 'smooth' });
  }));
  const setActive = id => navBtns.forEach(b => b.classList.toggle('is-active', b.dataset.target === id));
  const spy = new IntersectionObserver((entries) => {
    let best = null;
    for (const e of entries) {
      if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e;
    }
    if (best) setActive(best.target.id);
  }, { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
})();

window.addEventListener('beforeprint', () => {
  if (isPrint) return;
  // 1. Nifty Chart
  try {
    if (window.niftyChart) {
      const el = document.getElementById('nifty-chart');
      const w = el ? el.clientWidth : 0;
      const h = el ? el.clientHeight : 0;
      window.niftyChart.resize(w || 680, h || 180);
    }
  } catch (err) { console.error('niftyChart resize error:', err); }

  // 2. Hero Spark
  try {
    if (window.heroSpark) {
      const el = document.getElementById('hero-spark');
      const w = el ? el.clientWidth : 0;
      const h = el ? el.clientHeight : 0;
      window.heroSpark.resize(w || 300, h || 50);
    }
  } catch (err) { console.error('heroSpark resize error:', err); }

  // 3. VIX Spark
  try {
    if (window.vixSpark) {
      const el = document.getElementById('vix-spark');
      const w = el ? el.clientWidth : 0;
      const h = el ? el.clientHeight : 0;
      window.vixSpark.resize(w || 360, h || 70);
    }
  } catch (err) { console.error('vixSpark resize error:', err); }



  // 5. FII/DII Chart
  try {
    const fdChart = document.getElementById('fii-dii-chart');
    if (fdChart) {
      const w = fdChart.clientWidth || 680;
      const h = fdChart.clientHeight || 110;
      Plotly.relayout(fdChart, { width: w, height: h });
    }
  } catch (err) { console.error('fdChart relayout error:', err); }

  // 6. MMI Gauge
  try {
    const mmiGauge = document.getElementById('mmi-gauge');
    if (mmiGauge) {
      const w = mmiGauge.clientWidth || 260;
      const h = mmiGauge.clientHeight || 130;
      Plotly.relayout(mmiGauge, { width: w, height: h });
    }
  } catch (err) { console.error('mmiGauge relayout error:', err); }
});
</script>
</body>
</html>
