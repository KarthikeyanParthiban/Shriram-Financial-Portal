{# ============ Heatmap ============ #}
<section class="module" id="heatmap">
  <div class="print-header print-only">
    <span>Sector Breadth</span>
    <span>{{ generated_at.strftime('%d %b %Y') }}</span>
  </div>
  <div class="eyebrow"><span class="pip"></span>Breadth</div>
  <h2 class="module-title">NIFTY 50 heatmap</h2>
  <p class="module-sub">Every constituent at a glance — color encodes today's percentage change.</p>

  {% if constituents.available %}
  <div class="heatmap">
    {% for s in constituents.rows %}
      {%- set p = s.change_pct -%}
      {%- if p >= 1.5 -%}{% set cls = 'strong-up' %}
      {%- elif p >= 0.5 -%}{% set cls = 'up' %}
      {%- elif p >= -0.5 -%}{% set cls = 'flat' %}
      {%- elif p >= -1.5 -%}{% set cls = 'down' %}
      {%- else -%}{% set cls = 'strong-down' %}{%- endif -%}
      <div class="tile {{ cls }}">
        <span class="t-name">{{ s.stock }}</span>
        <span class="t-pct">{{ '{:+.2f}%'.format(p) }}</span>
      </div>
    {% endfor %}
  </div>

  {% set up_count = constituents.rows | selectattr('change_pct','ge',0) | list | length %}
  {% set total = constituents.rows | length %}
  {% if constituents.heatmap_insights %}
  <div class="insight-card" style="margin-top:20px; break-inside: avoid;">
    <h4><span class="ico">✦</span>AI Insights · Breadth & sector skew</h4>
    <ul class="insight-points">
      {% for pt in constituents.heatmap_insights %}
      <li class="{% if 'Market Breadth' in pt and up_count >= total/2 %}up{% elif 'Market Breadth' in pt %}down{% endif %}">
        <span class="bullet"></span><span>{{ pt | safe }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  {% endif %}
  <div class="print-footer print-only">
    <span>Market Digest Research · Subscription Copy</span>
    <span>Page 3 of 11</span>
  </div>
</section>

