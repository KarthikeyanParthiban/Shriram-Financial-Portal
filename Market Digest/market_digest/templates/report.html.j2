  <div class="print-footer print-only">
    <span>Market Digest Research · Subscription Copy</span>
    <span>Page 9 of 11</span>
  </div>
</section>

{# ============ Score (Sentiment Dashboard) ============ #}
<section class="module" id="score">
  <div class="print-header print-only">
    <span>Aggregate Digest Score</span>
    <span>{{ generated_at.strftime('%d %b %Y') }}</span>
  </div>
  <div class="eyebrow"><span class="pip"></span>Aggregate Read</div>
  <h2 class="module-title">Market Digest score</h2>
  <p class="module-sub">A weighted view of every signal across this report — bias, breadth, flows, vol, and global tone.</p>

  <div class="score-hero">
    <div>
      <div style="font-size:13px;color:var(--text-2);font-weight:500;letter-spacing:0.02em;text-transform:uppercase;">Today's score</div>
      <div class="score-num {{ 'up' if sentiment.score >= 60 else ('down' if sentiment.score <= 40 else 'neutral') }}">{{ sentiment.score }}%</div>
      <div class="score-label">{{ sentiment.label }}</div>
    </div>
    <div>
      <div class="score-gauge"><div class="needle" style="left: {{ [[sentiment.score, 2] | max, 98] | min }}%;"></div></div>
      <div class="score-scale"><span>Bearish</span><span>Neutral</span><span>Bullish</span></div>
      <p style="margin: 18px 0 0; font-size: 13px; color: var(--text-2); line-height: 1.5;">
        Derived from {{ sentiment.cards | length }} indicators across price, sentiment, flows,
        volatility and global markets. Updated each run.
      </p>
    </div>
  </div>

  <div class="indicator-grid">
    {% for c in sentiment.cards %}
    <div class="indicator">
      <div class="name">{{ c.name }}</div>
      <div class="desc">{{ c.desc }}</div>
      <div class="row">
        <span class="chip {{ 'up' if c.sentiment == 'BULLISH' else 'down' }}"><span class="dot"></span>{{ c.sentiment | capitalize }}</span>
      </div>
    </div>{% endfor %}
  </div>

  {% if sentiment.insights %}
  <div class="insight-card" style="margin-top:20px; break-inside: avoid;">
    <h4><span class="ico">✦</span>AI Insights · Tactical alignment</h4>
    <ul class="insight-points">
      {% for pt in sentiment.insights %}
      <li class="{% if 'Bullish' in sentiment.label %}up{% elif 'Bearish' in sentiment.label %}down{% endif %}">
        <span class="bullet"></span><span>{{ pt }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <div class="print-footer print-only">
    <span>Market Digest Research · Subscription Copy</span>
    <span>Page 10 of 11</span>
  </div>
</section>

{# ============ Disclosures ============ #}
<section class="module" id="disclosures" style="border-bottom: 0; padding-bottom: 24px;">
  <div class="print-header print-only">
    <span>Fine Print & Disclosures</span>
    <span>{{ generated_at.strftime('%d %b %Y') }}</span>
  </div>
  <div class="eyebrow"><span class="pip"></span>Fine Print</div>
  <h2 class="module-title">Disclosures</h2>
  <p class="module-sub">Privacy, disclaimers, terms, and data sources.</p>

  <div class="legal-grid">
    <div class="legal-block">
      <h4>Privacy</h4>
      <p>Market Digest is a personal-use generator. No personally identifiable information
