      <li><span class="bullet"></span><span>{{ pt }}</span></li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <div class="print-footer print-only">
    <span>Market Digest Research · Subscription Copy</span>
    <span>Page 8 of 11</span>
  </div>
</section>

{# ============ Silver ============ #}
<section class="module" id="silver">
  <div class="print-header print-only">
    <span>Chennai Silver Rates</span>
    <span>{{ generated_at.strftime('%d %b %Y') }}</span>
  </div>
  <div class="eyebrow"><span class="pip"></span>Chennai Rates</div>
  <h2 class="module-title">Silver Bullion</h2>
