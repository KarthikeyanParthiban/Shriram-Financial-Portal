  {% if silver.available %}
  {% if silver.today %}
  <div class="bullion-grid" style="margin-bottom:20px;">
    <div class="bullion-card">
      <div class="lbl">Silver · per gram</div>
      <div class="v">₹{{ '{:,.0f}'.format(silver.today.g1) }}</div>
      <div class="sub">100 g · ₹{{ '{:,.0f}'.format(silver.today.g100) }}</div>
    </div>
    <div class="bullion-card">
      <div class="lbl">Silver · per kg</div>
      <div class="v">₹{{ '{:,.0f}'.format(silver.today.kg1) }}</div>
    </div>
  </div>
  {% endif %}
  {% if silver.history %}
  <div class="tbl-card" style="margin-bottom:24px;">
    <div class="tbl-head"><h4>Last 10 sessions</h4><div class="meta">Per 1 gram and 1 kg · ₹</div></div>
    <table class="t">
      <thead><tr><th>Date</th><th class="num">1 Gram (₹)</th><th class="num">Change</th>
        <th class="num">1 Kg (₹)</th><th class="num">Change</th></tr></thead>
      <tbody>
        {% for d in silver.history %}
        <tr>
          <td>{{ d.date }}</td>
          <td class="num">{{ '{:,.0f}'.format(d.g1) }}</td>
          <td class="num"><span class="delta {{ 'up' if d.chg >= 0 else ('down' if d.chg < 0 else 'flat') }}">{{ '{:+,.0f}'.format(d.chg) if d.chg != 0 else '0' }}</span></td>
          <td class="num">{{ '{:,.0f}'.format(d.kg1) }}</td>
          <td class="num"><span class="delta {{ 'up' if d.chg_kg >= 0 else ('down' if d.chg_kg < 0 else 'flat') }}">{{ '{:+,.0f}'.format(d.chg_kg) if d.chg_kg != 0 else '0' }}</span></td>
        </tr>{% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
  {% endif %}

  {% if bullion_insights %}
